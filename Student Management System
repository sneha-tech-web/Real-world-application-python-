from flask import Flask, render_template_string, request, redirect
import sqlite3

app = Flask(__name__)

# Create database
def init_db():
    conn = sqlite3.connect("students.db")
    c = conn.cursor()
    c.execute("CREATE TABLE IF NOT EXISTS students (id INTEGER PRIMARY KEY, name TEXT, age INTEGER, course TEXT)")
    conn.commit()
    conn.close()

HTML = """
<!DOCTYPE html>
<html>
<head>
<title>Student Manager</title>
<style>
body {
    font-family: Arial;
    background: #eef2f3;
    margin: 0;
}
.header {
    background: #007BFF;
    color: white;
    padding: 15px;
    text-align: center;
}
.container {
    width: 60%;
    margin: auto;
    background: white;
    padding: 20px;
    margin-top: 20px;
    border-radius: 10px;
}
input, button {
    padding: 10px;
    margin: 5px;
}
button {
    background: blue;
    color: white;
    border: none;
}
.delete {
    background: red;
}
</style>
</head>

<body>

<div class="header">
    <h2>📋 Student Management System</h2>
</div>

<div class="container">

<form method="post">
    <input type="text" name="name" placeholder="Name" required>
    <input type="number" name="age" placeholder="Age" required>
    <input type="text" name="course" placeholder="Course" required>
    <button>Add Student</button>
</form>

<h3>Student List</h3>

{% for s in students %}
<p>
{{s[1]}} | Age: {{s[2]}} | Course: {{s[3]}}
<a href="/delete/{{s[0]}}">
<button class="delete">Delete</button>
</a>
</p>
{% endfor %}

</div>

</body>
</html>
"""

@app.route('/', methods=['GET','POST'])
def home():
    conn = sqlite3.connect("students.db")
    c = conn.cursor()

    if request.method == 'POST':
        name = request.form['name']
        age = request.form['age']
        course = request.form['course']
        c.execute("INSERT INTO students (name, age, course) VALUES (?,?,?)", (name, age, course))
        conn.commit()

    c.execute("SELECT * FROM students")
    data = c.fetchall()

    conn.close()
    return render_template_string(HTML, students=data)

@app.route('/delete/<int:id>')
def delete(id):
    conn = sqlite3.connect("students.db")
    c = conn.cursor()
    c.execute("DELETE FROM students WHERE id=?", (id,))
    conn.commit()
    conn.close()
    return redirect('/')

if __name__ == "__main__":
    init_db()
    app.run(debug=True)
